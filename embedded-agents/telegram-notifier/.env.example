# Copy to .env for local dev. Never commit .env.
# In production, all values are injected as Kubernetes Secrets.

# --- Required: Telegram ---
# Source via: secretctl get telegram-bot-token
# Martin: add to secretctl before deployment
TELEGRAM_BOT_TOKEN=

# --- Required: Ollama ---
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Config ---
AGENT_ID=telegram-notifier
CHANNEL_REGISTRY_PATH=/config/channel-registry.yaml
REPORTING_SINK_PATH=/reporting
MAX_SUMMARY_CHARS=280
