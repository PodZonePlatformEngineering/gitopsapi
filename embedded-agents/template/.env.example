# Copy to .env for local dev. Never commit .env.
# In production, all values are injected as Kubernetes Secrets.

# --- Required: Agent identity ---
AGENT_ID=my-agent
AGENT_DOMAIN=notification
AGENT_DESCRIPTION=Short description of what this agent does
AGENT_CAPABILITIES=capability-one,capability-two
# Optional — defaults to "http,scheduled"
AGENT_TRIGGER_MODES=http,scheduled
# Optional — defaults to "0.1.0"
AGENT_VERSION=0.1.0

# --- Required: Ollama ---
OLLAMA_MODEL=llama3.2
# In cluster, this points to the Ollama service. Locally, use host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Agent-specific secrets (add here; inject via K8s Secret in production) ---
# Example:
# TELEGRAM_BOT_TOKEN=<injected-by-k8s>
